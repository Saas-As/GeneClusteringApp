<Window x:Class="GeneClusteringWPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Кластеризация экспрессии генов" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Кластеризация экспрессии генов (k-means)" 
                   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Левая панель: управление -->
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="Gray" BorderThickness="1" 
                CornerRadius="5" Padding="10" Margin="5">
            <StackPanel>
                <TextBlock Text="Параметры" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock Text="Файл данных:"/>
                <Grid Margin="0,5,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="FilePathTextBox" Grid.Column="0" Height="25"/>
                    <Button x:Name="BrowseButton" Grid.Column="1" Content="Обзор" Width="60" 
                            Margin="5,0,0,0" Click="BrowseButton_Click"/>
                </Grid>

                <TextBlock Text="Метод нормализации:"/>
                <ComboBox x:Name="NormalizationComboBox" Margin="0,5,0,10" Height="25">
                    <ComboBoxItem Content="Z-score" IsSelected="True"/>
                    <ComboBoxItem Content="Min-Max"/>
                    <ComboBoxItem Content="Log2"/>
                    <ComboBoxItem Content="Без нормализации"/>
                </ComboBox>

                <TextBlock Text="Число кластеров (k):"/>
                <Grid Margin="0,5,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="KTextBox" Grid.Column="0" Text="0" Height="25"/>
                    <TextBlock Grid.Column="1" Text="(0 = авто)" Margin="5,0,0,0" 
                               VerticalAlignment="Center" Foreground="Gray" FontSize="10"/>
                </Grid>

                <Button x:Name="RunButton" Content="Запустить кластеризацию" 
                        Background="LightGreen" Height="35" Margin="0,10,0,0" 
                        Click="RunButton_Click"/>

                <Button x:Name="SaveButton" Content="Сохранить результаты" 
                        Background="LightBlue" Height="35" Margin="0,5,0,0" 
                        Click="SaveButton_Click" IsEnabled="False"/>

                <Separator Margin="0,15,0,10"/>

                <TextBlock Text="Результаты" FontSize="14" FontWeight="Bold"/>
                <TextBlock x:Name="GenesInfo" Text="Генов: -" Margin="0,5,0,0"/>
                <TextBlock x:Name="SamplesInfo" Text="Образцов: -"/>
                <TextBlock x:Name="KInfo" Text="Оптимальное k: -"/>
                <TextBlock x:Name="SilhouetteInfo" Text="Silhouette: -"/>
                <TextBlock x:Name="TimeInfo" Text="Время: -"/>

                <Separator Margin="0,10,0,10"/>

                <TextBlock Text="Размеры кластеров" FontWeight="Bold"/>
                <ListBox x:Name="ClusterSizesList" Height="150" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Центральная панель: график PCA -->
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Gray" BorderThickness="1" 
                CornerRadius="5" Padding="5" Margin="5" Width="50">
            <TextBlock Text="PCA" FontSize="12" FontWeight="Bold" 
                       VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="-90"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Border>

        <!-- Правая панель: график -->
        <Border Grid.Row="1" Grid.Column="2" BorderBrush="Gray" BorderThickness="1" 
                CornerRadius="5" Padding="5" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Визуализация (PCA)" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,5"/>

                <oxy:PlotView x:Name="PlotView" Grid.Row="1" Model="{Binding PlotModel}"/>
            </Grid>
        </Border>

        <!-- Статус бар -->
        <StatusBar Grid.Row="2" Grid.ColumnSpan="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>